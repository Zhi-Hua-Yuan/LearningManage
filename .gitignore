# =========================================================================
# 1. 编译产物与构建工具 (Maven)
# =========================================================================
target/
*.jar
*.war
*.ear
# 忽略 Maven 运行时产生的临时文件
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# =========================================================================
# 2. IDE 开发工具配置 (重点是 IntelliJ IDEA)
# =========================================================================
.idea/
*.iml
*.iws
*.ipr
out/
# 如果你偶尔使用 VS Code
.vscode/
.history/

# =========================================================================
# 3. 日志与临时文件
# =========================================================================
logs/
*.log
temp/

# =========================================================================
# 4. 操作系统相关
# =========================================================================
.DS_Store
Thumbs.db

# =========================================================================
# 5. 敏感配置文件 (核心建议)
# 建议忽略包含敏感信息的配置文件，或者只上传 .example 模板
src/main/resources/application-prod.yml
# 如果你在本地测试中有敏感配置，也可以忽略 dev 版本
# application-dev.yml